{
  "name": "animicro",
  "private": true,
  "version": "1.12.8",
  "type": "module",
  "scripts": {
    "dev:admin": "vite build --watch --mode admin",
    "dev:frontend": "vite build --watch --mode frontend",
    "build:admin": "vite build --mode admin",
    "build:frontend": "vite build --mode frontend",
    "build": "vite build --mode admin && vite build --mode frontend",
    "build:zips": "bash scripts/build.sh",
    "release:wp": "bash scripts/release-wp.sh",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "lenis": "^1.3.23",
    "motion": "^12.37.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0"
  }
}
